discord:
  token: <Your Token Here>
  user: "<Your User ID Here>"
  #logChannel: "<Channel ID Here>"  # スキル実行ログを投稿するチャンネル ID（省略可）

claude:
  model: claude-sonnet-4-5-20250929

channels:
  - name: エナジーメモ
    skill: daily-strength
    workdir: ../pksl-record  # スキル実行時のカレントディレクトリ（省略時はプロジェクトルート）
  - name: reddit
    skill: reddit-summary
    workdir: ../pksl-record
    cron:        # 定時実行する時刻リスト（省略可）
      - "10:00"  # HH:MM 形式
      - "22:00"
  - name: 料理メモ
    skill: dish-strength
    workdir: ../pksl-record  # スキル実行時のカレントディレクトリ（省略時はプロジェクトルート）
  - name: 雑談
    skill: ""                # 空文字列のとき通常の会話モード（セッションを継続する）
